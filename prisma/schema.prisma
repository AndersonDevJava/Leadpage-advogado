generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contato {
  id        Int            @id @default(autoincrement())
  nome      String
  email     String         @unique
  telefone  String         @unique
  area      AreaInteresse
  mensagem  String
}

enum AreaInteresse {
  DIREITO_EMPRESARIAL
  DIREITO_FAMILIA
  DIREITO_IMOBILIARIO
  DIREITO_CIVIL
  DIREITO_CONSUMIDOR
  DIREITO_TRABALHISTA
  OUTRO
}