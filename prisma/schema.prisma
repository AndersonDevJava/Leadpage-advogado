generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Contato {
  id        Int           @id @default(autoincrement())
  nome      String
  email     String
  telefone  String
  area      AreaInteresse
  mensagem  String
}

enum AreaInteresse {
  DIREITO_EMPRESARIAL
  DIREITO_FAMILIA
  DIREITO_IMOBILIARIO
  DIREITO_CIVIL
  DIREITO_CONSUMIDOR
  DIREITO_TRABALHISTA
  OUTRO
}